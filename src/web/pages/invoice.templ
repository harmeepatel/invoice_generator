							if model.Customer.Email == "" {
								<dd class={ infodd }>---</dd>
							} else {
								<dd class={ infodd }>{ model.Customer.Email }</dd>
							}
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>Phone</dt>
							<dd class={ infodd }>
								+{ model.Customer.PhoneExt }
