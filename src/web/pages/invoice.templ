				@tableRow(7, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(8, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(9, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(10, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(11, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(12, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(13, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(14, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(15, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(16, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(17, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(18, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(19, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(20, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(21, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(22, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
			</tbody>
		</table>
	</div>
}

