func formatFloat(n float32) string {
	s := fmt.Sprintf("%.2f", n)

	dot := strings.IndexByte(s, '.')
	intPart := s[:dot]
	fracPart := s[dot:]

	var out []byte
	l := len(intPart)

	for i := range l {
		if i > 0 && (l-i)%3 == 0 {
			out = append(out, ',')
		}
		out = append(out, intPart[i])
	}

	return string(out) + fracPart
}

templ tableRow(num uint, name string, hsn, qty uint, rate, disc, gst float32) {
	{{
		beforeDisc := (rate * float32(qty))
		discAmount := beforeDisc * (disc * 0.01)
		afterDisc := beforeDisc - discAmount
		total := afterDisc + (afterDisc * (gst * 0.01))
	}}
	<tr>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)), "rounded-tl-md rounded-bl-md" }>{ num }</td>
		<td class={ tblRow, templ.KV("bg-black/5", (num%2==0)) }>{ name }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)) }>{ hsn }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)) }>{ qty }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)) }>{ fmt.Sprintf("%.2f", rate) }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)) }>{ disc }%</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)) }>{ gst }%</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (num%2==0)), "rounded-tr-md rounded-br-md" }>
			{ formatFloat(total) }
		</td>
	</tr>
}

templ table() {
	<div class="overflow-x-auto">
		<table class="w-full text-sm text-left">
			<thead>
				<tr class="text-base border-b text-black/80">
					<th class={ tblHead, tc }>Sr.</th>
					<th class={ tblHead }>Item Name</th>
					<th class={ tblHead, tc }>HSN</th>
					<th class={ tblHead, tc }>Qty</th>
					<th class={ tblHead, tc }>Rate</th>
					<th class={ tblHead, tc }>Disc%</th>
					<th class={ tblHead, tc }>GST</th>
					<th class={ tblHead, tc }>Amount</th>
				</tr>
			</thead>
			<tbody>
				@tableRow(1, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(2, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(3, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
				@tableRow(4, "Digital Vitrified Tiles 600x600mm", 6907, 20, 100, 5, 5)
				@tableRow(5, "Premium Ceramic Wall Tiles 300x600mm", 6907, 45, 450.00, 5, 18)
