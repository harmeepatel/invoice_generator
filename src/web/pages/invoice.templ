					</dl>
				</div>
			</section>
		</div>
	</header>
}

func formatFloat(n float64) string {
	s := fmt.Sprintf("%.2f", n)

	dot := strings.IndexByte(s, '.')
	intPart := s[:dot]
	fracPart := s[dot:]

	var out []byte
	l := len(intPart)

	for i := range l {
		if i > 0 && (l-i)%3 == 0 {
			out = append(out, ',')
		}
		out = append(out, intPart[i])
	}

	return string(out) + fracPart
}

type Amount struct {
	beforeDisc float64
	discAmount float64
	afterDisc  float64
	gstAmount  float64
	total      float64
}

func newAmounts(qty int, rate, disc, gst float64) Amount {
	beforeDisc := (rate * float64(qty))
	discAmount := beforeDisc * (disc * 0.01)
	afterDisc := beforeDisc - discAmount
	gstAmount := afterDisc * (gst * 0.01)
	total := afterDisc + gstAmount
	return Amount{
		beforeDisc: beforeDisc,
		discAmount: discAmount,
		afterDisc:  afterDisc,
		gstAmount:  gstAmount,
		total:      total,
	}
}

type Amounts struct {
	amountMap map[string]Amount
	subTotal  float64
	cgst      float64
	sgst      float64
	igst      float64
}

func newAmountMap(list []model.ProductInfo) Amounts {
	am := Amounts{}
	for idx, item := range list {
		var key string
		if util.IsDev {
			key = fmt.Sprintf("%v%v", item.SerialNumber, idx)
		} else {
			key = item.SerialNumber
		}
		am.amountMap[key] = newAmounts(item.Quantity, item.Rate, item.Discount, item.GST)
	}
	return am
}

var amountMap = newAmountMap(model.Customer.Products)

templ tableRow(idx uint, srnum, name, hsn string, qty int, rate, disc, gst float64) {
	{{
		beforeDisc := (rate * float64(qty))
		discAmount := beforeDisc * (disc * 0.01)
		afterDisc := beforeDisc - discAmount
		gstAmount := afterDisc * (gst * 0.01)
		total := afterDisc + gstAmount
	}}
	<tr>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)), "rounded-tl-md rounded-bl-md" }>{ idx }</td>
		<td class={ tblRow, templ.KV("bg-black/5", (idx%2==0)) }>{ srnum }</td>
		<td class={ tblRow, templ.KV("bg-black/5", (idx%2==0)) }>{ name }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)) }>{ hsn }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)) }>{ qty }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)) }>{ fmt.Sprintf("%.2f", rate) }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)) }>{ disc }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)) }>{ gst }</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)) }>
			{ fmt.Sprintf("%.2f",
        gstAmount) }
		</td>
		<td class={ tblRow, tc, templ.KV("bg-black/5", (idx%2==0)), "rounded-tr-md rounded-br-md" }>
			{ formatFloat(total) }
		</td>
	</tr>
}

templ table() {
	<div class="overflow-x-auto">
		<table class="w-full text-sm text-left">
			<thead>
				<tr class="text-base border-b text-black/80">
					<th class={ tblHead, tc }>#</th>
					<th class={ tblHead }>S/N</th>
					<th class={ tblHead }>Item Name</th>
					<th class={ tblHead, tc }>HSN</th>
					<th class={ tblHead, tc }>Qty</th>
					<th class={ tblHead, tc }>Rate</th>
					<th class={ tblHead, tc }>Disc(%)</th>
					<th class={ tblHead, tc }>GST(%)</th>
					<th class={ tblHead, tc }>GST(₹)</th>
					<th class={ tblHead, tc }>Amount</th>
				</tr>
			</thead>
			<tbody>
				for idx, item := range model.Customer.Products {
					@tableRow(uint(idx)+1, item.SerialNumber, item.Name, item.Hsn, item.Quantity, item.Rate, item.Discount,
						item.GST)
				}
			</tbody>
		</table>
	</div>
}

