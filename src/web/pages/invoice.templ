package page

import (
	"ae_invoice/src/models"
	"ae_invoice/src/util"
	"ae_invoice/src/web/layouts"
	"fmt"
	"strings"
	"time"
)

const gap = "gap-6"
const h2 = "text-lg font-light uppercase"
const border = "border border-primary/20"
const bgBorder = "bg-primary/5" + " " + border
const infodd = "max-w-7/10"
const infoCompany = "text-lg text-end font-bold"
const infoField = "text-sm flex justify-between " + gap
const infoLabel = "text-xs font-light pt-0.5 opacity-60"
const infoContainer = "flex flex-col px-4 py-2.5 rounded-xl " + gap
const tblHead = "p-1"
const tblRow = "p-1"
const tc = " text-center"

templ Invoice(title string) {
	@layout.InvoiceBase(title) {
		<main class="flex justify-center">
			<div
				id="main-page"
				class="flex flex-col gap-6 p-8 font-cascadia text-black m-auto w-[210mm] min-h-[297mm] bg-white shadow-xl print:p-0 print:shadow-none"
			>
				@header()
				@table()
				@total()
				@footer()
			</div>
		</main>
	}
}

templ header() {
	{{
		today := time.Now()
		todayf := today.Format("02-01-2006")
		dueDatef := today.AddDate(0, 0, 15).Format("2006-01-02")
	}}
	<header class={ "flex flex-col text-justify justify-between" , gap }>
		<div class={ "grow flex items-center justify-between" , gap }>
			<div class={ "flex items-center" , gap }>
				<img src="/static/images/flogo.svg" class="w-24" alt="Company logo"/>
				<h1 class="font-bold text-7xl print:p-0">
					Invoice
				</h1>
			</div>
			<dl class="w-[180px] flex flex-col justify-between rounded-xl">
				<div class={ infoField, "font-bold" }>
					<dt class={ infoLabel }>Invoice No.</dt>
					<dd>123456</dd>
				</div>
				<div class={ infoField }>
					<dt class={ infoLabel }>Date</dt>
					<dd>
						<time datetime={ todayf }>
							{ todayf }
						</time>
					</dd>
				</div>
				<div class={ infoField }>
					<dt class={ infoLabel }>Due Date</dt>
					<dd>
						<time datetime={ dueDatef }>
							{ dueDatef }
						</time>
					</dd>
				</div>
				<div class={ infoField }>
					<dt class={ infoLabel }>Remark</dt>
					if model.ActiveInvoice.Customer.Remark == "" {
						<dd>---</dd>
					} else {
						<dd>{ model.ActiveInvoice.Customer.Remark }</dd>
					}
				</div>
			</dl>
		</div>
		<div class={ "flex" , gap }>
			<section class={ infoContainer, "w-1/2" , bgBorder }>
				<header class="flex justify-between items-center">
					<h2 class={ h2 }>To</h2>
					<span class={ infoCompany }>{ model.ActiveInvoice.Customer.CompanyName }</span>
				</header>
				<div>
					<dl class="flex flex-col gap-1">
						<div class={ infoField, "font-bold" }>
							<dt class={ infoLabel }>Name</dt>
							<dd class={ infodd }>{ model.ActiveInvoice.Customer.Name }</dd>
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>GSTIN</dt>
							<dd class={ infodd }>{ model.ActiveInvoice.Customer.Gstin }</dd>
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>Email</dt>
							if model.ActiveInvoice.Customer.Email == "" {
								<dd class={ infodd }>---</dd>
							} else {
								<dd class={ infodd }>{ model.ActiveInvoice.Customer.Email }</dd>
							}
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>Phone</dt>
							<dd class={ infodd }>
								+{ model.ActiveInvoice.Customer.PhoneExt }
								{ model.ActiveInvoice.Customer.Phone }
								<br/>
								<br/>
							</dd>
						</div>
						<address class={ infoField, "not-italic" }>
							<dt class={ infoLabel }>Address</dt>
							<dd class={ infodd }>{ model.ActiveInvoice.Customer.Address() }</dd>
						</address>
					</dl>
				</div>
			</section>
			<section class={ infoContainer, "w-1/2" , border }>
				<header class="flex justify-between items-center">
					<h2 class={ h2 }>From</h2>
					<span class={ infoCompany }>Achal Enterprise</span>
				</header>
				<div>
					<dl class="flex flex-col gap-1">
						<div class={ infoField, "font-bold" }>
							<dt class={ infoLabel }>Name</dt>
							<dd class={ infodd }>Rohit Patel</dd>
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>GSTIN</dt>
							<dd class={ infodd }>24AAZPP2696Q1ZE</dd>
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>Email</dt>
							<dd class={ infodd }>achalenterprise@yahoo.com</dd>
						</div>
						<div class={ infoField }>
							<dt class={ infoLabel }>Phone</dt>
							<dd class={ infodd }>
								+91 95588 90077
								<br/>
								+91 70963 04530
							</dd>
						</div>
						<address class={ infoField, "not-italic" }>
							<dt class={ infoLabel }>Address</dt>
							<dd class={ infodd }>
								G.F.-40, Chanakya Plaza, Nr.Swagat-3,
								New C.G. Road, Chandkheda, Ahmedabad,
								GUJARAT - 382424
							</dd>
						</address>
					</dl>
				</div>
			</section>
		</div>
	</header>
}

templ tableRow(idx uint, srnum, name, hsn string, qty int, rate, disc, gst float64) {
	{{
		key := strings.ToLower(srnum)
		if util.IsDev {
			key = fmt.Sprintf("%v%v", key, idx)
		}

		var bg string
		if idx%2 != 0 {
			bg = "bg-black/5"
		}
	}}
	<tr>
		<td class={ tblRow, bg, "rounded-tl-md rounded-bl-md" }>{ idx+1 }</td>
		<td class={ tblRow, bg }>{ srnum }</td>
		<td class={ tblRow, bg }>{ name }</td>
		<td class={ tblRow, bg }>{ hsn }</td>
		<td class={ tblRow, bg }>{ qty }</td>
		<td class={ tblRow, bg }>{ util.FormatFloat(rate) }</td>
		<td class={ tblRow, bg }>
			{ disc }%
			<span class="text-xs font-light">[{ util.FormatFloat(model.ActiveInvoice.Amount.Map[key].DiscAmount) }]</span>
		</td>
		<td class={ tblRow, bg }>
			{ gst }%
			<span class="text-xs font-light">[{ util.FormatFloat(model.ActiveInvoice.Amount.Map[key].GstAmount) }]</span>
		</td>
		<td class={ tblRow, bg, "rounded-tr-md rounded-br-md" }>
			{ util.FormatFloat(model.ActiveInvoice.Amount.Map[key].AfterDisc) }
		</td>
	</tr>
}

templ table() {
	<div class="overflow-x-auto">
		<table class="w-full text-sm text-left">
			<thead>
				<tr class="text-base border-b text-black/80">
					<th class={ tblHead }>#</th>
					<th class={ tblHead }>S/N</th>
					<th class={ tblHead }>Item Name</th>
					<th class={ tblHead }>HSN</th>
					<th class={ tblHead }>Qty<sup>(Q)</sup></th>
					<th class={ tblHead }>Rate<sup>(R)</sup></th>
					<th class={ tblHead }>Disc</th>
					<th class={ tblHead }>GST</th>
					<th class={ tblHead }>Amt<sup>(Qx(R-D))</sup></th>
				</tr>
			</thead>
			<tbody>
				for idx, item := range model.ActiveInvoice.Items {
					@tableRow(uint(idx), item.SerialNumber, item.Name, item.Hsn, item.Quantity, item.Rate, item.Discount,
						item.Gst)
				}
			</tbody>
		</table>
	</div>
}

templ total() {
	<div class={ "flex flex-col justify-between" , gap }>
		<div class={ "flex justify-between" , gap }>
			<div class="w-1/2">
				<h3 class="text-xs font-semibold uppercase text-neutral-400 mb-3">Terms & Conditions</h3>
				<ol class="text-[10px] text-neutral-500 list-none">
					<li class="flex gap-2">
						<span class="">1.</span>
						<span>We are not responsible for breakage color & size variation.</span>
					</li>
					<li class="flex gap-2">
						<span class="">2.</span>
						<span>Responsibility ceases after delivery from our shop.</span>
					</li>
					<li class="flex gap-2">
						<span class="">3.</span>
						<span>24% interest on delayed payments beyond 15 days.</span>
					</li>
					<li class="flex gap-2">
						<span class="">4.</span>
						<span>Goods once sold will not be taken back.</span>
					</li>
					<li class="flex gap-2">
						<span class="">5.</span>
						<span>Subject to Gandhinagar Jurisdiction only.</span>
					</li>
				</ol>
			</div>
			<div class="w-1/2">
				<dl class="flex flex-col justify-between h-full">
					<div class={ infoField, "font-bold" }>
						<dt class="text-base">Sub Total</dt>
						<dd class={ infodd, "text-base" }>{ util.FormatFloat(model.ActiveInvoice.Amount.SubTotal) }</dd>
					</div>
					<div class={ infoField, "font-bold" }>
						<dt>GST</dt>
						if model.ActiveInvoice.IgstRate == 0 {
							<dd class={ infodd }>{ util.FormatFloat(model.ActiveInvoice.Amount.GstTotal) }</dd>
						} else {
							<dd class={ infodd }>{ model.ActiveInvoice.Amount.Igst }</dd>
						}
					</div>
					<div class={ infoField }>
						<dt>CGST</dt>
						if model.ActiveInvoice.IgstRate == 0 {
							<dd class={ infodd }>{ util.FormatFloat(model.ActiveInvoice.Amount.Cgst) }</dd>
						} else {
							<dd class={ infodd }>---</dd>
						}
					</div>
					<div class={ infoField }>
						<dt>SGST</dt>
						if model.ActiveInvoice.IgstRate == 0 {
							<dd class={ infodd }>{ util.FormatFloat(model.ActiveInvoice.Amount.Sgst) }</dd>
						} else {
							<dd class={ infodd }>---</dd>
						}
					</div>
					<div class={ infoField }>
						<dt>IGST [{ util.FormatFloat(model.ActiveInvoice.IgstRate) }%]</dt>
						if model.ActiveInvoice.IgstRate == 0 {
							<dd class={ infodd }>---</dd>
						} else {
							<dd class={ infodd }>{ util.FormatFloat(model.ActiveInvoice.Amount.Igst) }</dd>
						}
					</div>
				</dl>
			</div>
		</div>
		<div class={ "flex justify-between items-center text-sm" , gap }>
			<div class={ "w-1/2 p-4 rounded-xl text-xs" , border }>
				<h3 class="text-sm mb-2">Bank Details</h3>
				<dl class="flex flex-col">
					<div class={ infoField }>
						<dt class={ infoLabel }>Bank</dt>
						<dd class={ infodd }>ICICI Bank Ltd.</dd>
					</div>
					<div class={ infoField }>
						<dt class={ infoLabel }>Branch</dt>
						<dd class={ infodd }>New C.G. Road, Chandkheda</dd>
					</div>
					<div class={ infoField }>
						<dt class={ infoLabel }>A/C</dt>
						<dd class={ infodd }>062505500142</dd>
					</div>
					<div class={ infoField }>
						<dt class={ infoLabel }>IFSC</dt>
						<dd class={ infodd }>ICIC0000625</dd>
					</div>
				</dl>
			</div>
			<div class={ "w-1/2 flex flex-col justify-between items-end self-stretch p-4 rounded-xl" , bgBorder }>
				<span class="text-primary font-semibold uppercase">total</span>
				<span class="text-2xl font-bold text-primary break-all">
					₹{ 
                util.FormatFloat(model.ActiveInvoice.Amount.Total) }
				</span>
			</div>
		</div>
		<div class="text-right pt-12">
			<p class="font-light border-t pt-2 inline-block px-4">Achal Enterprise</p>
		</div>
	</div>
}

templ footer() {
	<footer class="print-page-number">
		<span class="page-number"></span>
	</footer>
}
